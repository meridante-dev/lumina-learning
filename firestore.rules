rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin accounts — identified by their signed-in email.
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'admin@edenrise.com', 'info@edenrise.com', 'john@edenrise.com'
      ];
    }

    // Each learner reads/writes their OWN profile + state.
    // Admins may READ every member's doc (for the Leader's Cockpit) but never write it.
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Community forum — everyone reads; signed-in users post; authors (or admins)
    // edit/delete; any signed-in user may react/bump.
    match /forum_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null && (
                       resource.data.authorUid == request.auth.uid
                       || request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['likes', 'likedBy', 'replyCount', 'lastActivity'])
                    );
      allow delete: if request.auth != null
                    && (resource.data.authorUid == request.auth.uid || isAdmin());

      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if request.auth != null && (
                         resource.data.authorUid == request.auth.uid
                         || request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['likes', 'likedBy'])
                      );
        allow delete: if request.auth != null
                      && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }
  }
}
