rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each learner can read and write only their OWN profile + state document.
    // Nobody can read anyone else's data. This is what makes the public
    // firebaseConfig safe to ship in the browser.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
